{
  "name": "miniregie-tv",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others -n server,client -c cyan,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch --env-file=.env server/src/index.ts",
    "dev:client": "vite dev",
    "build": "npm run build:server && npm run build:client",
    "build:server": "esbuild server/src/index.ts --bundle=false --format=esm --outdir=server/dist --platform=node",
    "build:client": "vite build",
    "start": "node --env-file=.env server/dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "check": "biome check .",
    "check:svelte": "svelte-kit sync && svelte-check --tsconfig ./client/tsconfig.json",
    "format": "biome format --write .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "dev:reset": "node -e \"require('fs').rmSync('miniregie.db',{force:true});require('fs').rmSync('miniregie.db-wal',{force:true});require('fs').rmSync('miniregie.db-shm',{force:true});require('fs').writeFileSync('state.json',JSON.stringify({jam:{status:'idle',startedAt:null,endsAt:null,timeRemaining:null},activeApp:'pre-jam-idle',panicState:false,panicMessage:''},null,2));\" && npx tsx --env-file=.env server/src/db/seed-dev.ts"
  },
  "dependencies": {
    "@tsparticles/engine": "^3.9.1",
    "better-sqlite3": "^12.6.2",
    "bits-ui": "^2.16.3",
    "cookie": "^1.1.1",
    "drizzle-orm": "^0.45.1",
    "express": "^4.21.0",
    "get-youtube-id": "^1.0.1",
    "gsap": "^3.14.2",
    "iso8601-duration": "^2.1.3",
    "jose": "^6.2.2",
    "js-confetti": "^0.13.1",
    "multer": "^2.1.1",
    "paneforge": "^1.0.2",
    "probe-image-size": "^7.2.3",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@playwright/test": "^1.58.2",
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/better-sqlite3": "^7.6.0",
    "@types/cookie": "^1.0.0",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.4.0",
    "@types/probe-image-size": "^7.2.5",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.9",
    "esbuild": "^0.27.3",
    "jsdom": "^29.0.0",
    "lightningcss": "^1.32.0",
    "supertest": "^7.2.2",
    "svelte": "^5.54.0",
    "svelte-check": "^4.4.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18"
  }
}
