{
  "name": "@miniregie/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node --watch --experimental-strip-types src/index.ts",
    "build": "esbuild src/index.ts --bundle=false --format=esm --outdir=dist --platform=node",
    "build:watch": "esbuild src/index.ts --bundle=false --format=esm --outdir=dist --platform=node --watch"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "cookie": "^1.0.0",
    "express": "^4.21.0",
    "multer": "^2.0.0",
    "socket.io": "^4.8.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/cookie": "^1.0.0",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.4.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.9.3"
  }
}
